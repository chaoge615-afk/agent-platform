# ==================== LLM API 配置 ====================

# 默认 LLM 提供者（anthropic / openai）
LLM_PROVIDER=anthropic

# Anthropic 兼容接口（Anthropic 官方 / MiniMax / 其他 Anthropic SDK 兼容服务）
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI 兼容接口（OpenAI / DeepSeek / MiniMax / 其他 OpenAI SDK 兼容服务）
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# MiniMax 配置示例（Anthropic 兼容）
# ANTHROPIC_API_KEY=your_minimax_key
# ANTHROPIC_BASE_URL=https://api.minimax.chat/anthropic
# ANTHROPIC_MODEL=MiniMax-M2

# DeepSeek 配置示例（OpenAI 兼容）
# OPENAI_API_KEY=your_deepseek_key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ==================== MCP Server 地址 ====================
# content-analysis-system 提供的 MCP Server（Phase 13 实现）
BILIBILI_MCP_URL=http://localhost:9001/sse
RAG_MCP_URL=http://localhost:9002/sse
SQL_MCP_URL=http://localhost:9003/sse

# ==================== 记忆系统 ====================
# ChromaDB 本地嵌入式存储路径
CHROMA_DATA_PATH=./data/chroma_db
MEMORY_COLLECTION=agent_memory

# ==================== 服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8001
LOG_LEVEL=INFO
